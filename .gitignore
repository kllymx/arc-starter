# Python runtime
.venv/
__pycache__/
*.py[cod]
# Note: uv.lock IS committed (pinned deps so every teammate resolves identically).

# ARC runtime artifacts (generated by hooks + scripts during normal use)
scripts/*.log
scripts/state.json
scripts/last-flush.json
scripts/session-flush-*.md
reports/

# Private tier (company mode) — local-only second brain, never pushed to the
# shared/company remote. Personal context (comp, health, candid notes, career
# thoughts) lives here and stays on the founder's machine. See SHARING.md.
private/

# Harness research scrapes — scratch material, not framework code
.firecrawl/

# Claude Code ephemeral state
.claude/worktrees/
# Runtime git-sync log written by the hooks — local state, not shared history
.claude/last-sync.log

# OS
.DS_Store
Thumbs.db
