{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-start.sh",
            "timeout": 15000,
            "statusMessage": "Loading ARC wiki context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-end-wrapper.sh",
            "timeout": 30000,
            "statusMessage": "Capturing session knowledge..."
          }
        ]
      }
    ]
  }
}
