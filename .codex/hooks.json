{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Loading ARC wiki context..."
          },
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash hooks/git-pull.sh",
            "timeout": 30,
            "statusMessage": "Pulling latest from GitHub..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash hooks/pre-compact-wrapper.sh",
            "timeout": 10,
            "statusMessage": "Capturing context before compaction..."
          }
        ]
      }
    ]
  }
}
