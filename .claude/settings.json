{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash hooks/session-start.sh",
        "timeout": 15000
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "bash hooks/pre-compact-wrapper.sh",
        "timeout": 30000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash hooks/session-end-wrapper.sh",
        "timeout": 30000
      }
    ]
  }
}
