{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_CODE=1 bash hooks/session-start.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_CODE=1 bash hooks/pre-compact-wrapper.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_CODE=1 bash hooks/session-end-wrapper.sh",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
